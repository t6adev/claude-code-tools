{
  "name": "claude-code-tools",
  "version": "1.0.0",
  "description": "Claude Code tools library — skills, agents, hooks, MCP configs",
  "bin": {
    "claude-code-tools": "./dist/install.js"
  },
  "files": [
    "dist/",
    "tools/"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/install.ts",
    "prepare": "tsc",
    "check": "pnpm run --parallel \"/^check:.*/\"",
    "check:lint": "oxlint",
    "check:fmt": "oxfmt --check",
    "fix": "pnpm run --parallel \"/^fix:.*/\"",
    "fix:lint": "oxlint --fix",
    "fix:fmt": "oxfmt"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
