{
  "name": "Python",
  "description": "Python プロジェクト向けの sandbox 推奨設定",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    }
  }
}
