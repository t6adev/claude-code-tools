{
  "name": "General",
  "description": "汎用的な開発環境向けの sandbox 推奨設定",
  "notes": [
    "git worktree をプロジェクト外に作成する場合は、",
    "filesystem.allowWrite にそのディレクトリを追加してください。",
    "例: \"filesystem\": { \"allowWrite\": [\"../\"] }"
  ],
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowRead": ["~/.config/gh"]
    },
    "network": {
      "allowedDomains": ["github.com", "api.github.com", "*.githubusercontent.com"],
      "allowLocalBinding": true
    },
    "enableWeakerNetworkIsolation": true
  }
}
