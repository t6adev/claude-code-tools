{
  "name": "Node.js",
  "description": "Node.js プロジェクト向けの sandbox 推奨設定",
  "notes": [
    "git worktree をプロジェクト外に作成する場合は、",
    "filesystem.allowWrite にそのディレクトリを追加してください。",
    "例: \"filesystem\": { \"allowWrite\": [\"../\"] }"
  ],
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": ["~/.local/share/pnpm"]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "registry.yarnpkg.com"
      ]
    }
  }
}
